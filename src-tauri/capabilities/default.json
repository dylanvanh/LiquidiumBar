{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal LiqWatch desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get-store",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-save",
    "autostart:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://liquidium.fi/*" },
        { "url": "https://github.com/Liquidium-Inc/liquidium-sdk*" }
      ]
    }
  ]
}
