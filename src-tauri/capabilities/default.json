{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal LiquidiumBar desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get-store",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-save",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://liquidium.fi/*" },
        { "url": "https://app.liquidium.fi/*" },
        { "url": "https://github.com/Liquidium-Inc/liquidium-sdk*" },
        { "url": "https://dashboard.internetcomputer.org/transaction/*" },
        { "url": "https://etherscan.io/tx/*" },
        { "url": "https://mempool.space/tx/*" }
      ]
    }
  ]
}
